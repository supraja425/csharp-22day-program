{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // NEW SECTION: where is our database?
  // This is the SAME connection string style you used when scaffolding
  // in section 3.6 - now saved here so the running APPLICATION (not
  // just the scaffold command) can also connect to CareBridgeDB.
  "ConnectionStrings": {
    "CareBridgeDb": "Server=localhost;Database=CareBridgeDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  // NEW SECTION: where is the Insurance Service?
  // This is the ADDRESS (including port) of CareBridge.InsuranceService.Api
  // - the project we built in Part 2. CareBridge.Api will send its
  // eligibility-check requests to this address.
  "InsuranceServiceSettings": {
    "BaseUrl": "https://localhost:7141"
  }
}

